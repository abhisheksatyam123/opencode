{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "opencode",
  "version": "1.14.49",
  "description": "opencode-derived TUI CLI (single-package fork)",
  "type": "module",
  "license": "MIT",
  "private": true,
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": ">=1.3.13"
  },
  "bin": {
    "opencode": "./bin/opencode"
  },
  "exports": {
    "./*": "./src/*.ts"
  },
  "imports": {
    "#db": {
      "bun": "./src/storage/db.bun.ts",
      "node": "./src/storage/db.node.ts",
      "default": "./src/storage/db.bun.ts"
    },
    "#pty": {
      "bun": "./src/filesystem/pty/pty.bun.ts",
      "node": "./src/filesystem/pty/pty.node.ts",
      "default": "./src/filesystem/pty/pty.bun.ts"
    }
  },
  "scripts": {
    "prepare": "effect-language-service patch || true",
    "dev": "bun run ./script/dev.ts",
    "typecheck": "tsgo --noEmit",
    "test": "NODE_OPTIONS='--no-warnings=ExperimentalWarning' vitest run --passWithNoTests",
    "test:ci": "mkdir -p .artifacts/unit && vitest run --passWithNoTests --reporter=junit --reporter-outfile=.artifacts/unit/junit.xml --coverage",
    "test:notes": "vitest run --passWithNoTests",
    "test:changed": "vitest --changed --passWithNoTests",
    "test:related": "vitest related --passWithNoTests",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --passWithNoTests --coverage",
    "test:failed": "echo 'test folders removed; no failed tests to rerun'",
    "test:slow": "echo 'test folders removed; no slow-test report'",
    "test:gaps": "echo 'test folders removed; skipping test-gap scan'",
    "test:no-focused": "bun run script/no-focused-tests.ts",
    "probe:providers": "bun run script/provider-endpoint-probe.ts",
    "notes:bootstrap": "bun run script/notes-bootstrap.ts",
    "notes:audit:ci": "bun run script/notes-audit-ci.ts",
    "notes:audit:contracts": "bun run script/contract-notes-audit.ts",
    "tool-cards:generate": "OPENCODE_NOTES_ROOT=${OPENCODE_NOTES_ROOT:-$HOME/notes} bun run script/generate-tool-cards.ts",
    "tool-cards:check": "vitest run --passWithNoTests",
    "schema:model-routing-config": "bun run script/model-routing-config-schema.ts schema/model-routing-config.schema.json",
    "validate:model-routing-config": "bun run script/model-routing-config-validate.ts opencode.json",
    "test:model-routing-config": "vitest run --passWithNoTests",
    "test:model-routing-contract": "bun run test:model-routing-config",
    "schema:model-routing-contract": "bun run schema:model-routing-config",
    "validate:model-routing-contract": "bun run validate:model-routing-config",
    "fix-node-pty": "bun run script/fix-node-pty.ts",
    "upgrade-opentui": "bun run script/upgrade-opentui.ts",
    "db": "bun drizzle-kit",
    "mentor:lint": "bun run src/agent/mentor/mentor-lint.ts",
    "test:contract-guard": "bun run script/contract-guard.ts",
    "format": "bun prettier --write .",
    "check": "bun run typecheck && bun run validate && bun run test:no-focused && bun prettier --check .",
    "build": "bun run script/build.ts",
    "sdk:build": "cd src/surface/web/official/packages/sdk/js && bun run build",
    "dep-check": "depcruise src --config .dependency-cruiser.cjs",
    "lint": "eslint src/ --max-warnings=9999",
    "validate:boundaries": "bun run script/validate.ts",
    "validate": "bun run validate:boundaries",
    "test:no-standalone-undefined": "bun run script/no-standalone-undefined-guard.ts",
    "prompt:lint": "bun run script/prompt-lint.ts"
  },
  "workspaces": {
    "catalog": {
      "@effect/platform-node": "4.0.0-beta.43",
      "@types/bun": "1.3.11",
      "@types/cross-spawn": "6.0.6",
      "@octokit/rest": "22.0.0",
      "ulid": "3.0.1",
      "@types/node": "22.13.9",
